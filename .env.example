# Base de datos
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE=
SUPABASE_URL=

# Token de autentificacion 
JWT_SECRET=

# Email 
EMAIL_USER=
EMAIL_PASS=

# Servidor
PORT=
NODE_ENV=

# Transbank (en integracion)
TRANSBANK_COMMERCE_CODE=
TRANSBANK_API_KEY=
TRANSBANK_ENVIRONMENT=

FRONTEND_URL=

# CORS (URLs permitidas separadas por comas - solo en producción)
ALLOWED_ORIGINS=

# --- Envío ---
# estimated (default): tarifa según distancia desde La Reina (sin API externa).
# starken: cotización real vía API Starken (requiere credenciales abajo).
SHIPPING_PROVIDER=estimated

# Parámetros del estimado (origen por defecto: comuna La Reina)
# ESTIMATED_SHIPPING_ORIGIN_LAT=-33.4467
# ESTIMATED_SHIPPING_ORIGIN_LNG=-70.5386
# ESTIMATED_SHIPPING_BASE_PESOS=2500
# ESTIMATED_SHIPPING_PER_KM=120
# ESTIMATED_SHIPPING_MIN_PESOS=2500
# ESTIMATED_SHIPPING_MAX_PESOS=45000

# --- Starken (solo si SHIPPING_PROVIDER=starken) ---
# Base REST QA por defecto; en producción te la entrega el ejecutivo Starken.
STARKEN_REST_BASE_URL=https://restservices-qa.starken.cl/apiqa/starkenservices/rest
# Una de estas dos formas de auth (según documentación del portal developers.starken.cl):
# STARKEN_AUTHORIZATION_HEADER=Basic base64usuario
# STARKEN_AUTH_USER=
# STARKEN_AUTH_PASSWORD=
STARKEN_CODIGO_CIUDAD_ORIGEN=1
STARKEN_RUT_CLIENTE=1
STARKEN_DEFAULT_KILOS=1
STARKEN_DEFAULT_ALTO=30
STARKEN_DEFAULT_ANCHO=30
STARKEN_DEFAULT_LARGO=30
# Totales checkout (tolerancia cotización envío vs cliente)
STARKEN_QUOTE_TOLERANCE_PESOS=50
